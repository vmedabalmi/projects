    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^8.17.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "pino": "^8.17.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
